import urllib.request
import urllib.parse
import http.cookiejar
import json

cj = http.cookiejar.CookieJar()
opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cj))

# Test login
data = urllib.parse.urlencode({'username': 'user1', 'password': '123456'}).encode()
try:
    req = urllib.request.Request('http://127.0.0.1:5000/login', data=data, method='POST')
    resp = opener.open(req)
    print(f'Login: {resp.status} - {resp.geturl()}')
except Exception as e:
    print(f'Login ERROR: {e}')
    exit(1)

# Test chat with different scenarios
test_cases = [
    ("查询订单", "test_order_query"),
    ("你好", "test_greeting"),
    ("我想退款", "test_refund"),
    ("投诉电话多少", "test_complaint"),
]

for text, desc in test_cases:
    data = json.dumps({'text': text}).encode()
    try:
        req = urllib.request.Request(
            'http://127.0.0.1:5000/api/chat',
            data=data,
            method='POST',
            headers={'Content-Type': 'application/json'}
        )
        resp = opener.open(req)
        result = json.loads(resp.read())
        print(f'\n--- {desc} ---')
        print(f'  text: {text}')
        print(f'  status: {result.get("status")}')
        print(f'  emotion: {result.get("emotion")}')
        rep = (result.get("reply") or "")
        print(f'  reply: {rep[:120]}')
    except Exception as e:
        print(f'\n--- {desc} ---')
        print(f'  ERROR: {e}')


# ============================================================
# 环境变量配置文件模板
# 复制为 .env 后填入真实值
# ============================================================

# Flask 会话签名密钥（必填，使用随机长字符串）
SECRET_KEY=your-secret-key-here

# DeepSeek / OpenAI 兼容接口密钥（必填，否则 AI 回复降级为兜底文案）
LLM_API_KEY=sk-your-api-key-here

# ============================================================
# 可选配置（有默认值）
# ============================================================

# LLM 接口地址，默认 DeepSeek
LLM_BASE_URL=https://api.deepseek.com

# 使用的模型名称
LLM_MODEL=deepseek-chat

# 数据库 URI，默认 SQLite
DATABASE_URL=sqlite:///site.db

# SocketIO 异步模式：Windows 用 threading，Linux/Mac 可用 eventlet
SOCKETIO_ASYNC_MODE=threading

# 是否开启调试模式（生产环境请保持 false）
FLASK_DEBUG=false

# ============================================================
# 演示数据初始化（可选）
# ============================================================
ENABLE_DEMO_SEED=true
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=your-admin-password
DEMO_USER_USERNAME=user1
DEMO_USER_PASSWORD=your-user-password

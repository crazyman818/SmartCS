# ============================================================
# SmartCS environment template
# Copy this file to .env and fill real values.
# ============================================================

# App mode: development / testing / production
SMARTCS_ENV=development

# Required in production. Use a long random value.
SECRET_KEY=your-secret-key-here

# DeepSeek / OpenAI-compatible API. Empty key enables fallback replies.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Database. Relative SQLite paths are stored under Flask instance path.
DATABASE_URL=sqlite:///site.db

# Socket.IO
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
SOCKETIO_MESSAGE_QUEUE=

# Runtime behavior
FLASK_DEBUG=false
HTTPS=false
LOAD_EMOTION_MODEL_ON_STARTUP=false
ENABLE_DEMO_SEED=true

# Demo accounts created when ENABLE_DEMO_SEED=true
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=your-admin-password
DEMO_USER_USERNAME=user1
DEMO_USER_PASSWORD=your-user-password
